<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>4.0.7</version>
        <relativePath/>
    </parent>

    <groupId>com.wshake</groupId>
    <artifactId>java-admin-parent</artifactId>
    <version>0.0.1-SNAPSHOT</version>
    <packaging>pom</packaging>
    <name>java-admin-parent</name>
    <description>Java Admin Backend - parent reactor</description>

    <modules>
        <module>java-admin-common</module>
        <module>java-admin-service</module>
        <module>java-admin-infra</module>
        <module>java-admin-api</module>
    </modules>

    <properties>
        <java.version>17</java.version>
        <maven.compiler.source>17</maven.compiler.source>
        <maven.compiler.target>17</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>

        <!-- 框架版本 -->
        <easy-query.version>3.2.12</easy-query.version>
        <sa-token.version>1.45.0</sa-token.version>
        <redisson.version>4.5.0</redisson.version>  <!-- 4.x 含 RedissonAutoConfigurationV4 适配 SB 4 -->
        <knife4j.version>4.5.0</knife4j.version>
        <mysql.version>9.2.0</mysql.version>
        <lombok.version>1.18.38</lombok.version>
        <flyway.version>10.20.0</flyway.version>
        <spring.flayway.verison>4.0.7</spring.flayway.verison>
        <spring-cloud-alibaba.version>2025.1.0.0</spring-cloud-alibaba.version>

        <!-- Java 工具链（2026-06-14 集成） -->
        <spotless.version>3.6.0</spotless.version>
        <palantir-java-format.version>2.92.0</palantir-java-format.version>

        <!-- Error Prone 2.x（2026-06-15 集成；2.50.0 = 2.x 最新稳定，2026-06-10 发布，需 JDK 21+） -->
        <errorprone.version>2.50.0</errorprone.version>
    </properties>

    <dependencyManagement>
        <dependencies>
            <!-- Spring Cloud Alibaba BOM（配套 SB 4） -->
            <dependency>
                <groupId>com.alibaba.cloud</groupId>
                <artifactId>spring-cloud-alibaba-dependencies</artifactId>
                <version>${spring-cloud-alibaba.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>

            <!-- 项目内 4 模块 -->
            <dependency>
                <groupId>com.wshake</groupId>
                <artifactId>java-admin-common</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.wshake</groupId>
                <artifactId>java-admin-service</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.wshake</groupId>
                <artifactId>java-admin-infra</artifactId>
                <version>${project.version}</version>
            </dependency>

            <!-- Easy-Query（Spring Boot 4 专用 starter） -->
            <dependency>
                <groupId>com.easy-query</groupId>
                <artifactId>sql-springboot4-starter</artifactId>
                <version>${easy-query.version}</version>
            </dependency>
            <dependency>
                <groupId>com.easy-query</groupId>
                <artifactId>sql-processor</artifactId>
                <version>${easy-query.version}</version>
            </dependency>
            <dependency>
                <groupId>com.easy-query</groupId>
                <artifactId>sql-mysql</artifactId>
                <version>${easy-query.version}</version>
            </dependency>

            <!-- Sa-Token（1.45.0；Spring Boot 4 专用 starter + Redis Template 走 Spring Data Redis） -->
            <dependency>
                <groupId>cn.dev33</groupId>
                <artifactId>sa-token-spring-boot4-starter</artifactId>
                <version>${sa-token.version}</version>
            </dependency>
            <dependency>
                <groupId>cn.dev33</groupId>
                <artifactId>sa-token-core</artifactId>
                <version>${sa-token.version}</version>
            </dependency>
            <!-- ⚠️ 切到 sa-token-redis-template（Spring Data Redis + Lettuce 实现），
                 不再用 sa-token-redisson。原因是 sa-token-redisson 拉 redisson:3.x 与 starter 4.5.0 冲突。 -->
            <dependency>
                <groupId>cn.dev33</groupId>
                <artifactId>sa-token-redis-template</artifactId>
                <version>${sa-token.version}</version>
            </dependency>

            <!-- Redisson core（不用 spring-boot-starter，避免 SB 4 + starter V4 各种兼容问题；
                 业务侧需要时由 infra/RedissonConfig.java 手工构造 RedissonClient）。
                 sa-token 现在用 sa-token-redis-template（Spring Data Redis），
                 所以 redisson 不是必需依赖；保留是给业务侧留口子（分布式锁、限流、原子计数等）。 -->
            <dependency>
                <groupId>org.redisson</groupId>
                <artifactId>redisson-spring-boot-starter</artifactId>
                <version>${redisson.version}</version>
            </dependency>

            <!-- Knife4j（Spring Boot 4 用 Jakarta starter） -->
            <dependency>
                <groupId>com.github.xiaoymin</groupId>
                <artifactId>knife4j-openapi3-jakarta-spring-boot-starter</artifactId>
                <version>${knife4j.version}</version>
            </dependency>

            <!-- Flyway -->
            <dependency>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-starter-flyway</artifactId>
                <version>${spring.flayway.verison}</version>
            </dependency>
            <dependency>
                <groupId>org.flywaydb</groupId>
                <artifactId>flyway-mysql</artifactId>
                <version>${flyway.version}</version>
            </dependency>

            <!-- MySQL 驱动 -->
            <dependency>
                <groupId>com.mysql</groupId>
                <artifactId>mysql-connector-j</artifactId>
                <version>${mysql.version}</version>
            </dependency>

            <!-- Spring Cloud Alibaba Nacos Config -->
            <dependency>
                <groupId>com.alibaba.cloud</groupId>
                <artifactId>spring-cloud-starter-alibaba-nacos-config</artifactId>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <!--
      项目实际依赖(继承给所有子模块)。
      error_prone_core / error_prone_check_api / error_prone_annotation 三个 jar
      用 provided 作用域:编译期 javac -classpath 可见,运行 jar 不打包。
      目的:让 ServiceLoader 在 fork=true 模式下能从 javac -classpath 找到 EP plugin
      类(同时 annotationProcessorPaths 也放 EP jars,让 transitive 都在 processorpath)。
    -->
    <dependencies>
        <dependency>
            <groupId>com.google.errorprone</groupId>
            <artifactId>error_prone_core</artifactId>
            <version>${errorprone.version}</version>
            <scope>provided</scope>
        </dependency>
        <dependency>
            <groupId>com.google.errorprone</groupId>
            <artifactId>error_prone_check_api</artifactId>
            <version>${errorprone.version}</version>
            <scope>provided</scope>
        </dependency>
        <dependency>
            <groupId>com.google.errorprone</groupId>
            <artifactId>error_prone_annotation</artifactId>
            <version>${errorprone.version}</version>
            <scope>provided</scope>
        </dependency>
    </dependencies>

    <build>
        <pluginManagement>
            <plugins>
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-compiler-plugin</artifactId>
                    <configuration>
                        <source>${java.version}</source>
                        <target>${java.version}</target>
                        <annotationProcessorPaths>
                            <path>
                                <groupId>org.projectlombok</groupId>
                                <artifactId>lombok</artifactId>
                                <version>${lombok.version}</version>
                            </path>
                            <!-- Easy-Query APT -->
                            <path>
                                <groupId>com.easy-query</groupId>
                                <artifactId>sql-processor</artifactId>
                                <version>${easy-query.version}</version>
                            </path>
                        </annotationProcessorPaths>
                    </configuration>
                </plugin>
            </plugins>
        </pluginManagement>
        <plugins>
            <!--
              maven-compiler-plugin（含 Error Prone 2.50.0，2026-06-15 集成）
              走 EP 官方 install guide 推荐的 "fork=false + .mvn/jvm.config" 路径:
              - mvn 与 javac 共享同一 JVM,ServiceLoader 走 plugin classloader 找 EP 类
              - 10 个 add-exports / 2 个 add-opens 不进 compilerArgs(MCP 3.14.1
                在 fork 模式下会吞带 J 前缀的 export 旗标);改放进 .mvn/jvm.config,
                mvn 启动时读取 → 写到 JVM 启动参数 → javac 与 mvn 共用同一 JVM
                时自然继承
              - error_prone_core / check_api / annotation 放 plugin 的 dependencies,
                让 ServiceLoader 找得到
              与 Spotless(格式) / Checkstyle(命名/复杂度) 形成三层质量门禁。
            -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.11.0</version>
                <configuration>
                    <source>${java.version}</source>
                    <target>${java.version}</target>
                    <fork>true</fork>
                    <annotationProcessorPaths>
                        <path>
                            <groupId>org.projectlombok</groupId>
                            <artifactId>lombok</artifactId>
                            <version>${lombok.version}</version>
                        </path>
                        <!-- Easy-Query APT -->
                        <path>
                            <groupId>com.easy-query</groupId>
                            <artifactId>sql-processor</artifactId>
                            <version>${easy-query.version}</version>
                        </path>
                        <!--
                          Error Prone 注解 + plugin 都进 processorpath。
                          关键:error_prone_core 必须进 processorpath,它的 transitive
                          (Guava、protobuf、dataflow 等) 由 MCP 自动拉到 processorpath。
                          同时 error_prone_core 也走 project <dependencies>(provided 作用域),
                          让 ServiceLoader 也能从 javac -classpath 找到 ErrorProneJavacPlugin 类。
                        -->
                        <path>
                            <groupId>com.google.errorprone</groupId>
                            <artifactId>error_prone_annotations</artifactId>
                            <version>${errorprone.version}</version>
                        </path>
                        <path>
                            <groupId>com.google.errorprone</groupId>
                            <artifactId>error_prone_core</artifactId>
                            <version>${errorprone.version}</version>
                        </path>
                        <path>
                            <groupId>com.google.errorprone</groupId>
                            <artifactId>error_prone_check_api</artifactId>
                            <version>${errorprone.version}</version>
                        </path>
                        <path>
                            <groupId>com.google.errorprone</groupId>
                            <artifactId>error_prone_annotation</artifactId>
                            <version>${errorprone.version}</version>
                        </path>
                        <path>
                            <groupId>io.github.eisop</groupId>
                            <artifactId>dataflow-errorprone</artifactId>
                            <version>3.41.0-eisop1</version>
                        </path>
                    </annotationProcessorPaths>
                    <compilerArgs>
                        <!--
                          EP 2.50.0 强制旗标:
                          - XDcompilePolicy=simple / should-stop=ifError=FLOW
                            EP 拒绝 javac 的 by-todo / INIT 默认策略
                          - XDaddTypeAnnotationsToSymbol=true
                            EP 2.50.0 在 JDK 21 上必需(JEP 396 内部 API 调整)
                          - Xplugin:ErrorProne 启用 javac plugin
                          10 个 add-exports / 2 个 add-opens 放 .mvn/jvm.config。
                          jvm.config 只对 mvn 主 JVM 生效;但 MCP 3.11.0 fork=true 模式下
                          实际看到 [forked debug release 17] —— fork 进程继承 mvn JVM
                          的 add-exports 是 jvm.config 之外的另一条路;我们靠 project
                          <dependencies> 让 error_prone_core 在 classpath 上
                          (ServiceLoader 找得到),add-exports 在 MCP 透传给 forked JVM。
                        -->
                        <arg>-J--add-exports=jdk.compiler/com.sun.tools.javac.api=ALL-UNNAMED</arg>
                        <arg>-J--add-exports=jdk.compiler/com.sun.tools.javac.file=ALL-UNNAMED</arg>
                        <arg>-J--add-exports=jdk.compiler/com.sun.tools.javac.main=ALL-UNNAMED</arg>
                        <arg>-J--add-exports=jdk.compiler/com.sun.tools.javac.model=ALL-UNNAMED</arg>
                        <arg>-J--add-exports=jdk.compiler/com.sun.tools.javac.parser=ALL-UNNAMED</arg>
                        <arg>-J--add-exports=jdk.compiler/com.sun.tools.javac.processing=ALL-UNNAMED</arg>
                        <arg>-J--add-exports=jdk.compiler/com.sun.tools.javac.tree=ALL-UNNAMED</arg>
                        <arg>-J--add-exports=jdk.compiler/com.sun.tools.javac.util=ALL-UNNAMED</arg>
                        <arg>-J--add-opens=jdk.compiler/com.sun.tools.javac.code=ALL-UNNAMED</arg>
                        <arg>-J--add-opens=jdk.compiler/com.sun.tools.javac.comp=ALL-UNNAMED</arg>
                        <arg>-XDcompilePolicy=simple</arg>
                        <arg>--should-stop=ifError=FLOW</arg>
                        <arg>-XDaddTypeAnnotationsToSymbol=true</arg>
                        <arg>-Xplugin:ErrorProne</arg>
                    </compilerArgs>
                </configuration>
            </plugin>

            <!-- Spotless: palantir-java-format 自动格式化
                 通过 `mvn spotless:apply` 全量格式化；
                 `mvn spotless:check` 仅检查（exit ≠ 0 表示未格式化）。
                 lefthook pre-commit 也会调 apply 并 re-add。 -->
            <plugin>
                <groupId>com.diffplug.spotless</groupId>
                <artifactId>spotless-maven-plugin</artifactId>
                <version>${spotless.version}</version>
                <configuration>
                    <java>
                        <palantirJavaFormat>
                            <version>${palantir-java-format.version}</version>
                        </palantirJavaFormat>
                    </java>
                </configuration>
            </plugin>

            <!-- Checkstyle: Palantir 自家规则集（命名 / 复杂度 / 风格规约）
                 severity = error；绑 verify phase；mvn verify / mvn package 会跑。
                 lefthook pre-push 也跑 `mvn checkstyle:check`（fast feedback）。
                 规则集与配置在 build-tools/checkstyle/ 下：
                   - checkstyle.xml          Palantir Baseline 规则集（gradle-baseline 仓库 raw）
                   - checkstyle-suppressions.xml   现有 4 模块基线屏蔽
                   - custom-suppressions.xml       用户自定义（当前为空）

                 版本说明：SB 4.0.7 父 POM 的 pluginManagement 已经锁定了
                 maven-checkstyle-plugin 3.6.0；此处显式声明版本号只是为了让 Maven
                 不再 warn "build.plugins.plugin.version is missing"。 -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-checkstyle-plugin</artifactId>
                <version>3.6.0</version>
                <configuration>
                    <configLocation>${maven.multiModuleProjectDirectory}/build-tools/checkstyle/checkstyle.xml</configLocation>
                    <suppressionsLocation>${maven.multiModuleProjectDirectory}/build-tools/checkstyle/checkstyle-suppressions.xml</suppressionsLocation>
                    <includeTestSourceDirectory>true</includeTestSourceDirectory>
                    <failOnViolation>true</failOnViolation>
                    <violationSeverity>error</violationSeverity>
                    <consoleOutput>true</consoleOutput>
                    <linkXRef>false</linkXRef>
                    <!--
                      Skip generated sources (Easy-Query APT output under
                      target/generated-sources/) — those files are machine-written
                      and not under our control. Only check hand-written source.
                    -->
                    <sourceDirectories>
                        <sourceDirectory>${project.basedir}/src/main/java</sourceDirectory>
                    </sourceDirectories>
                    <testSourceDirectories>
                        <testSourceDirectory>${project.basedir}/src/test/java</testSourceDirectory>
                    </testSourceDirectories>
                    <!--
                      `config_loc` is referenced by Palantir's checkstyle.xml
                      via its built-in SuppressionFilter (reads
                      ${config_loc}/checkstyle-suppressions.xml and
                      ${config_loc}/custom-suppressions.xml). The maven-checkstyle-plugin
                      doesn't set it automatically, so we pass it via the
                      `propertyExpansion` parameter (which supports Maven
                      variable interpolation). We use
                      `${maven.multiModuleProjectDirectory}` (the directory of
                      the parent POM) so the same config works for both the
                      parent POM and every child module.
                    -->
                    <propertyExpansion>config_loc=${maven.multiModuleProjectDirectory}/build-tools/checkstyle</propertyExpansion>
                </configuration>
                <executions>
                    <execution>
                        <id>checkstyle-verify</id>
                        <phase>verify</phase>
                        <goals>
                            <goal>check</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>
