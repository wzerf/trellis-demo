# java-admin dev 依赖环境变量模板
# 复制为 .env 后填入真实值；.env 不要提交到 git
# 端口策略：4000 段（详见 docker-compose.yml 头部注释）

# MySQL
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=javaadmin_dev
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_PORT=4336

# Redis
REDIS_PASSWORD=
REDIS_PORT=4379

# Nacos（java-admin 端通过 NACOS_CONFIG_ENABLED 决定是否连）
# Nacos HTTP 端口 = 4848（gRPC = 5848，由 Nacos 自动派生）
NACOS_SERVER_ADDR=127.0.0.1:4848
NACOS_USER=nacos
NACOS_PASSWORD=nacos
