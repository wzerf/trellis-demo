# 环境变量配置文件
VITE_ENV=dev

# 端口号
VITE_SERVER_PORT=7000

# 跨域：Vite 把 /api/* 代理到 mock 的 /api/*
# createProxy 会去掉前缀，所以 target 写 /api/，最终转发到 http://localhost:4000/api/X
VITE_PROXY='[["/api/", "http://localhost:4000/api/"]]'

# API 基础地址：走 Vite 代理到 mock 的 /api
VITE_API_URL=/api

# SSE地址（vben 最小骨架暂不用，留空）
VITE_SSE_URL=
