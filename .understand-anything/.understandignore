/.claude/
/.opencode/
/.codex/
/.trae/
/.vscode/
/.idea/
/.codegraph/
/.trellis/
/.understand-anything/
/.understand-anything-tmp/

# --- Vendored sub-monorepos (excluded from root pnpm-workspace.yaml) ---
# These are full third-party admin templates that the demo uses as showcase
# apps. They have their own pnpm-workspace.yaml and are NOT part of the
# trellis-demo monorepo proper. Analyzing them inflates the graph with
# off-the-shelf admin code unrelated to the starter's design.
